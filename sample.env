# =============================================================================
# GitHub AI PR Reviewer - Sample Environment File
# =============================================================================
#
# How to use:
#   cp sample.env .env
#   # then edit .env and replace placeholder values with your real secrets
#   docker compose up --build -d
#
# Local service URLs (after docker compose up):
#   Gateway      -> http://localhost:8100
#   Webhook      -> http://localhost:8101
#   Orchestrator -> http://localhost:8102
#   Reviewer     -> http://localhost:8103
#   Learner      -> http://localhost:8104
#
# =============================================================================

# --- PostgreSQL (docker-compose postgres service) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=codereviewer

# --- Database URL ---
# Use this when running with docker compose (host = postgres, internal port 5432)
# IMPORTANT: Do NOT leave this empty
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/codereviewer

# If using an external/local Postgres instead of docker postgres, example:
# DATABASE_URL=postgresql+asyncpg://user:password@host.docker.internal:5432/codereviewer

# --- Redis (Celery broker + backend) ---
REDIS_URL=redis://redis:6379/0

# --- GitHub Webhook Secret ---
# Set the same value in your GitHub App / webhook settings
# Example only — replace with your own secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- GitHub App credentials ---
# Required for orchestrator (fetch PR diff) and reviewer (post PR review)
# Find these in: GitHub -> Settings -> Developer settings -> GitHub Apps -> Your App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# --- OpenAI API Key ---
# Required for orchestrator AI agents (LangGraph + GPT)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Inter-service URLs ---
# Defaults below work inside Docker Compose network — usually no change needed
WEBHOOK_SERVICE_URL=http://webhook:8001
ORCHESTRATOR_SERVICE_URL=http://orchestrator:8002
REVIEWER_SERVICE_URL=http://reviewer:8003
LEARNER_SERVICE_URL=http://learner:8004
